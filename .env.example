# Shared SMTP configuration
SMTP_HOST=smtp.mailcoat.com
SMTP_PORT=587
SMTP_USER=info@annia.no
SMTP_PASS=
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
MAIL_FROM=info@annia.no
MAIL_TO=info@annia.no

# Registro endpoint (fase 1)
REGISTRO_INTERNAL_TO=info@annia.no
# mailbox_only (default): no file persistence, relies on internal mailbox as record
# file_local: appends NDJSON locally (not durable on serverless)
REGISTRO_STORAGE_MODE=mailbox_only
# Only used when REGISTRO_STORAGE_MODE=file_local
REGISTRO_FILE_PATH=data/registro-submissions.ndjson
